# ---------------------------------------------------------------------------
# 디지털 교육 포털 환경 변수 예시
# 실제 값은 이 파일에 넣지 말고 `.env.local`에 넣으세요. (.env.local 은 커밋되지 않습니다)
# ---------------------------------------------------------------------------

# Supabase 프로젝트 URL (예: https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Supabase anon(public) 키 — 프런트엔드에 노출되어도 되는 공개 키입니다.
# service_role 키는 절대로 프런트엔드나 저장소에 넣지 마세요.
VITE_SUPABASE_ANON_KEY=

# (선택) 교수자 계정 이메일 목록. 쉼표로 구분.
# 실제 권한 부여는 이 값이 아니라 Supabase의 profiles.role 로 결정됩니다.
# 이 값은 UI에서 "교수자 신청 안내" 등을 표시할 때 참고용으로만 쓸 수 있습니다.
VITE_INSTRUCTOR_HINT_EMAILS=
